local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local destroyedRemotes = {
    Healing = false,
    Generator = false
}

local function DisableSkillCheckEvent(folderName)
    if destroyedRemotes[folderName] then return true end
    
    local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not Remotes then return false end
    
    local targetFolder = Remotes:FindFirstChild(folderName)
    if not targetFolder then return false end
    
    local SkillCheckEvent = targetFolder:FindFirstChild("SkillCheckEvent")
    if not SkillCheckEvent then return false end
    
    SkillCheckEvent:Destroy()
    destroyedRemotes[folderName] = true
    return true
end

local function DestroyBoth()
    destroyedRemotes.Healing = false
    destroyedRemotes.Generator = false
    DisableSkillCheckEvent("Healing")
    DisableSkillCheckEvent("Generator")
end

local playerGui = LocalPlayer:WaitForChild("PlayerGui")

playerGui.ChildAdded:Connect(function(gui)
    if gui:IsA("ScreenGui") then
        local name = gui.Name:lower()
        if name:find("cutscene") or name:find("intro") or name:find("cinematic") or name:find("round") then
            task.wait(0.3)
            DestroyBoth()
            gui:Destroy()
        end
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    DestroyBoth()
end)

local remotes = ReplicatedStorage:FindFirstChild("Remotes")
if remotes then
    remotes.ChildAdded:Connect(function(child)
        if child.Name == "Healing" or child.Name == "Generator" then
            task.wait(0.1)
            DisableSkillCheckEvent(child.Name)
            
            child.ChildAdded:Connect(function(grandChild)
                if grandChild.Name == "SkillCheckEvent" then
                    grandChild:Destroy()
                end
            end)
        end
    end)
end

DestroyBoth()
