local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")

local function GetRole()
    if not LocalPlayer.Team then return "Unknown" end
    local name = LocalPlayer.Team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" or name == "Survivor" then return "Survivor" end
    return "Lobby"
end

-- Auto load: loop menunggu role Survivor
spawn(function()
    while task.wait(0.5) do
        local role = GetRole()
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChild("Humanoid")
        
        if role == "Survivor" and character and humanoid and humanoid.Health > 0 then
            print("Auto load: Survivor terdeteksi - Snake Step siap")
            
            -- ===== SCRIPT SNAKE STEP =====
            local perkLevel = 3 -- 1=90%, 2=100%, 3=110%
            local speedMultiplier = (perkLevel == 1 and 1.9) or (perkLevel == 2 and 2.0) or 2.1
            local originalWalkSpeed = humanoid.WalkSpeed
            local isCrouching = false
            local isBoostActive = false
            
            -- Fungsi untuk mengecek apakah sedang crouching
            -- Metode 1: Deteksi berdasarkan input keyboard (CTRL atau C)
            local function isCrouchKeyPressed()
                return UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or
                       UserInputService:IsKeyDown(Enum.KeyCode.RightControl) or
                       UserInputService:IsKeyDown(Enum.KeyCode.C)
            end
            
            -- Metode 2: Deteksi berdasarkan ukuran karakter (crouching biasanya mengecilkan karakter)
            local function isCharacterCrouching()
                local char = LocalPlayer.Character
                if not char then return false end
                
                local humanoidRootPart = char:FindFirstChild("HumanoidRootPart")
                local head = char:FindFirstChild("Head")
                
                if humanoidRootPart and head then
                    local distance = (head.Position.Y - humanoidRootPart.Position.Y)
                    -- Jika jarak head ke root kurang dari normal (sekitar 4-5 stud), berarti crouching
                    return distance < 3.5
                end
                return false
            end
            
            -- Loop pengecekan crouching
            while task.wait(0.1) do -- loop lebih cepat untuk responsif
                local currentChar = LocalPlayer.Character
                local currentHum = currentChar and currentChar:FindFirstChild("Humanoid")
                if not currentChar or not currentHum or currentHum.Health <= 0 then
                    -- Mati/respawn, reset kecepatan
                    if isBoostActive then
                        currentHum.WalkSpeed = originalWalkSpeed
                        isBoostActive = false
                    end
                    break
                end
                
                -- Update originalWalkSpeed jika berubah (misal kena efek killer)
                if not isBoostActive and currentHum.WalkSpeed ~= originalWalkSpeed then
                    originalWalkSpeed = currentHum.WalkSpeed
                end
                
                -- Deteksi crouching (gabungkan kedua metode)
                local crouching = isCrouchKeyPressed() or isCharacterCrouching()
                
                if crouching and not isBoostActive then
                    -- Aktifkan speed boost saat crouch
                    currentHum.WalkSpeed = originalWalkSpeed * speedMultiplier
                    isBoostActive = true
                    print("Snake Step aktif - Crouch speed boost " .. (speedMultiplier * 100 - 100) .. "%")
                    
                    -- Efek visual: outline hijau/kuning saat boost aktif
                    local highlight = currentChar:FindFirstChild("SnakeStepHighlight")
                    if not highlight then
                        highlight = Instance.new("Highlight")
                        highlight.Name = "SnakeStepHighlight"
                        highlight.FillTransparency = 0.8
                        highlight.OutlineColor = Color3.new(0.8, 0.8, 0) -- kuning
                        highlight.Parent = currentChar
                    end
                    
                elseif not crouching and isBoostActive then
                    -- Nonaktifkan boost saat berdiri
                    currentHum.WalkSpeed = originalWalkSpeed
                    isBoostActive = false
                    print("Snake Step nonaktif - Berdiri")
                    
                    -- Hapus efek visual
                    local highlight = currentChar:FindFirstChild("SnakeStepHighlight")
                    if highlight then highlight:Destroy() end
                end
                
                -- Jika boost aktif tapi kecepatan tidak sesuai, perbaiki
                if isBoostActive then
                    currentHum.WalkSpeed = originalWalkSpeed * speedMultiplier
                end
            end
        end
    end
end)

print("Auto load Snake Step aktif - menunggu role Survivor...")
