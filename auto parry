-- Violence District - Auto Parry Script
-- Loadstring: loadstring(game:HttpGet("https://pastebin.com/raw/3sTs5ifF"))()
-- Developer, ini script auto parry yang sudah saya rangkai khusus untuk game Violence District.
-- Fitur ini akan secara otomatis memblokir serangan killer berdasarkan jarak dan timing.

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:wait()
local Humanoid = Character:WaitForChild("Humanoid")
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

-- Konfigurasi Auto Parry
local Config = {
    ParryDistance = 12,          -- Jarak maksimum deteksi serangan (studs)
    ParryTiming = 0.05,          -- Timing parry (semakin kecil semakin cepat)
    Enabled = true,              -- Status auto parry
    VisualFeedback = true,       -- Efek visual saat parry berhasil
    SoundFeedback = true         -- Suara saat parry berhasil
}

-- Variabel internal
local lastParryTime = 0
local parryCooldown = 0.3
local currentKiller = nil

-- Fungsi deteksi killer terdekat
local function GetNearestKiller()
    local nearestDistance = Config.ParryDistance
    local nearestKiller = nil
    
    for _, v in pairs(workspace:GetChildren()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= Character then
            local humanoidRoot = v:FindFirstChild("HumanoidRootPart")
            if humanoidRoot and HumanoidRootPart then
                local distance = (humanoidRoot.Position - HumanoidRootPart.Position).Magnitude
                if distance < nearestDistance then
                    nearestDistance = distance
                    nearestKiller = v
                end
            end
        end
    end
    
    return nearestKiller, nearestDistance
end

-- Fungsi efek visual parry
local function PlayParryEffect()
    if not Config.VisualFeedback then return end
    
    local attachment = Instance.new("Attachment")
    attachment.Parent = HumanoidRootPart
    attachment.Position = Vector3.new(0, 1, 0)
    
    local particleEmitter = Instance.new("ParticleEmitter")
    particleEmitter.Parent = attachment
    particleEmitter.Texture = "rbxasset://textures/particles/sparkles_main.dds"
    particleEmitter.Rate = 200
    particleEmitter.Lifetime = NumberRange.new(0.2)
    particleEmitter.SpreadAngle = Vector2.new(360, 360)
    particleEmitter.VelocityInheritance = 0
    particleEmitter.Speed = NumberRange.new(5)
    particleEmitter.Enabled = true
    
    game:GetService("Debris"):AddItem(attachment, 0.3)
end

-- Fungsi eksekusi parry
local function ExecuteParry()
    local currentTime = tick()
    if currentTime - lastParryTime < parryCooldown then
        return false
    end
    
    lastParryTime = currentTime
    
    -- Trigger parry action
    Humanoid.Jump = true
    wait(Config.ParryTiming)
    
    if Config.VisualFeedback then
        PlayParryEffect()
    end
    
    return true
end

-- Deteksi serangan berdasarkan animasi killer
local function DetectAttackFromKiller(killer, distance)
    if not killer then return false end
    
    -- Cek tool yang dipegang killer
    local tool = killer:FindFirstChildOfClass("Tool")
    if tool and tool:FindFirstChild("Handle") then
        local handle = tool.Handle
        local velocity = handle:GetVelocity()
        
        -- Jika velocity tinggi, kemungkinan sedang menyerang
        if velocity.Magnitude > 20 then
            return true
        end
    end
    
    -- Cek animasi sedang berlangsung
    local humanoid = killer:FindFirstChild("Humanoid")
    if humanoid then
        local animTrack = humanoid:FindFirstChild("Animator")
        if animTrack then
            for _, track in pairs(animTrack:GetPlayingAnimationTracks()) do
                local animName = track.Animation.AnimationId
                if animName:match("attack") or animName:match("swing") or animName:match("slash") then
                    return true
                end
            end
        end
    end
    
    -- Berdasarkan jarak (jika terlalu dekat)
    if distance < 5 then
        return true
    end
    
    return false
end

-- Loop utama auto parry
local function AutoParryLoop()
    if not Config.Enabled then return end
    
    local character = LocalPlayer.Character
    if not character or not HumanoidRootPart or Humanoid.Health <= 0 then return end
    
    local killer, distance = GetNearestKiller()
    
    if killer and DetectAttackFromKiller(killer, distance) then
        ExecuteParry()
    end
end

-- Toggle fungsi dengan tombol (P)
local function ToggleAutoParry()
    Config.Enabled = not Config.Enabled
    print("[Auto Parry] " .. (Config.Enabled and "Enabled" or "Disabled"))
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.P then
        ToggleAutoParry()
    end
end)

-- Menjalankan auto parry setiap frame
RunService.Heartbeat:Connect(AutoParryLoop)

print("[Auto Parry] Script loaded successfully! Press 'P' to toggle.")

