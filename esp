local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local config = {
    enabled = true,
    killerColor = Color3.fromRGB(255, 93, 108),
    survivorColor = Color3.fromRGB(64, 224, 255)
}

local function GetRole()
    if not localPlayer.Team then return "Unknown" end
    local name = localPlayer.Team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" then return "Survivor" end
    return "Lobby"
end

local function shouldRun()
    local role = GetRole()
    return role == "Killer" or role == "Survivor"
end

local activeHighlights = {}

local function applyESP(character, color)
    if not character then return end
    
    local existing = activeHighlights[character]
    if existing then
        existing:Destroy()
        activeHighlights[character] = nil
    end
    
    local h = Instance.new("Highlight")
    h.Name = "H"
    h.Adornee = character
    h.FillColor = color
    h.OutlineColor = color
    h.FillTransparency = 0.8
    h.OutlineTransparency = 0.3
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent = character
    activeHighlights[character] = h
end

local function clearAllESP()
    for char, highlight in pairs(activeHighlights) do
        if highlight then
            pcall(function() highlight:Destroy() end)
        end
    end
    activeHighlights = {}
end

local function updateESP()
    if not config.enabled or not shouldRun() then
        clearAllESP()
        return
    end
    
    local localRole = GetRole()
    local isKiller = localRole == "Killer"
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character and player.Team then
            local char = player.Character
            local teamName = player.Team.Name:lower()
            local isEnemy = (isKiller and teamName:find("survivor")) or (not isKiller and teamName:find("killer"))
            
            if isEnemy then
                local color = isKiller and config.survivorColor or config.killerColor
                if activeHighlights[char] and activeHighlights[char].FillColor == color then
                    -- sudah benar, skip
                else
                    applyESP(char, color)
                end
            else
                if activeHighlights[char] then
                    activeHighlights[char]:Destroy()
                    activeHighlights[char] = nil
                end
            end
        end
    end
end

-- Event: karakter muncul
local function onCharacterAdded(player)
    return function()
        task.wait(0.2)
        updateESP()
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= localPlayer then
        player.CharacterAdded:Connect(onCharacterAdded(player))
    end
end

Players.PlayerAdded:Connect(function(player)
    if player ~= localPlayer then
        player.CharacterAdded:Connect(onCharacterAdded(player))
    end
end)

localPlayer:GetPropertyChangedSignal("Team"):Connect(function()
    task.wait(0.1)
    clearAllESP()
    updateESP()
end)

-- Loop utama (1 detik sekali, bukan 0.5)
task.spawn(function()
    while true do
        updateESP()
        task.wait(1)  -- Lebih ringan dari 0.5
    end
end)

-- Eksekusi awal
task.wait(0.5)
updateESP()
