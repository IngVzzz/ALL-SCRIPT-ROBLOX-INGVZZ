local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function GetRole()
    if not LocalPlayer.Team then return "Unknown" end
    local name = LocalPlayer.Team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" or name == "Survivor" then return "Survivor" end
    return "Lobby"
end

-- Auto load: loop menunggu role Survivor
spawn(function()
    while task.wait(0.5) do
        local role = GetRole()
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChild("Humanoid")
        
        if role == "Survivor" and character and humanoid and humanoid.Health > 0 then
            print("Auto load: Survivor terdeteksi - On My Own siap")
            
            -- ===== SCRIPT ON MY OWN =====
            local perkLevel = 3 -- 1=5%, 2=10%, 3=15% speed boost
            local speedMultiplier = (perkLevel == 1 and 1.05) or (perkLevel == 2 and 1.10) or 1.15
            local checkRadius = 50 -- jarak dalam stud untuk mendeteksi survivor lain
            local originalWalkSpeed = humanoid.WalkSpeed
            local isBoostActive = false
            
            local function getNearbySurvivors()
                local nearby = 0
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                if not rootPart then return 0 end
                
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer then
                        local playerTeam = player.Team
                        if playerTeam and (playerTeam.Name == "Survivors" or playerTeam.Name == "Survivor") then
                            local playerChar = player.Character
                            local playerRoot = playerChar and playerChar:FindFirstChild("HumanoidRootPart")
                            if playerRoot and playerChar:FindFirstChild("Humanoid") and playerChar.Humanoid.Health > 0 then
                                local distance = (rootPart.Position - playerRoot.Position).Magnitude
                                if distance <= checkRadius then
                                    nearby = nearby + 1
                                end
                            end
                        end
                    end
                end
                return nearby
            end
            
            while task.wait(0.5) do
                local currentChar = LocalPlayer.Character
                local currentHum = currentChar and currentChar:FindFirstChild("Humanoid")
                if not currentChar or not currentHum or currentHum.Health <= 0 then
                    -- Mati/respawn, reset kecepatan
                    if isBoostActive then
                        currentHum.WalkSpeed = originalWalkSpeed
                        isBoostActive = false
                    end
                    break -- keluar inner loop, kembali ke outer loop menunggu respawn
                end
                
                local nearbyCount = getNearbySurvivors()
                
                if nearbyCount == 0 and not isBoostActive then
                    -- Sendirian, aktifkan boost
                    currentHum.WalkSpeed = originalWalkSpeed * speedMultiplier
                    isBoostActive = true
                    print("On My Own aktif - Sendirian! Speed boost " .. (speedMultiplier * 100 - 100) .. "%")
                    
                    -- Efek visual (opsional: ubah warna karakter atau partikel)
                    local highlight = currentChar:FindFirstChild("OnMyOwnHighlight")
                    if not highlight then
                        highlight = Instance.new("Highlight")
                        highlight.Name = "OnMyOwnHighlight"
                        highlight.FillTransparency = 0.7
                        highlight.OutlineColor = Color3.new(0, 0.5, 1) -- biru
                        highlight.Parent = currentChar
                    end
                    
                elseif nearbyCount > 0 and isBoostActive then
                    -- Ada survivor lain, matikan boost
                    currentHum.WalkSpeed = originalWalkSpeed
                    isBoostActive = false
                    print("On My Own nonaktif - Ada survivor lain di sekitar")
                    
                    -- Hapus efek visual
                    local highlight = currentChar:FindFirstChild("OnMyOwnHighlight")
                    if highlight then highlight:Destroy() end
                end
                
                -- Update originalWalkSpeed jika berubah (misal kena efek killer)
                if currentHum.WalkSpeed ~= originalWalkSpeed and not isBoostActive then
                    originalWalkSpeed = currentHum.WalkSpeed
                elseif isBoostActive then
                    -- Pastikan speed boost tetap terjaga
                    currentHum.WalkSpeed = originalWalkSpeed * speedMultiplier
                end
            end
        end
    end
end)

print("Auto load On My Own aktif - menunggu role Survivor...")
