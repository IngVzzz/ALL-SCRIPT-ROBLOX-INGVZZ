local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local Hook = {
    Players = {
        ["Killer"] = {Color = Color3.fromRGB(255, 93, 108), On = true},
        ["Survivor"] = {Color = Color3.fromRGB(64, 224, 255), On = true}
    }
}

local function GetRole()
    if not localPlayer.Team then return "Unknown" end
    local name = localPlayer.Team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" then return "Survivor" end
    return "Lobby"
end

local function ESP(obj, color)
    if obj:FindFirstChild("H") then return end
    local h = Instance.new("Highlight")
    h.Name = "H"
    h.Adornee = obj
    h.FillColor = color
    h.OutlineColor = color
    h.FillTransparency = 0.8
    h.OutlineTransparency = 0.38
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent = obj
end

local function removeAllESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then
            local highlight = p.Character:FindFirstChild("H")
            if highlight then
                highlight:Destroy()
            end
        end
    end
end

local function updateESP()
    local myRole = GetRole()
    if myRole ~= "Survivor" and myRole ~= "Killer" then
        removeAllESP()
        return
    end
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Team then
            if p.Team.Name == "Killer" and Hook.Players["Killer"].On then
                ESP(p.Character, Hook.Players["Killer"].Color)
            elseif p.Team.Name == "Survivors" and Hook.Players["Survivor"].On then
                ESP(p.Character, Hook.Players["Survivor"].Color)
            end
        end
    end
end

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= localPlayer and p.Character and p.Team then
        if p.Team.Name == "Killer" then
            ESP(p.Character, Hook.Players["Killer"].Color)
        elseif p.Team.Name == "Survivors" then
            ESP(p.Character, Hook.Players["Survivor"].Color)
        end
    end
end

Players.PlayerAdded:Connect(function(player)
    if player ~= localPlayer then
        player.CharacterAdded:Connect(function(character)
            task.wait(0.3)
            if player.Team then
                if player.Team.Name == "Killer" then
                    ESP(character, Hook.Players["Killer"].Color)
                elseif player.Team.Name == "Survivors" then
                    ESP(character, Hook.Players["Survivor"].Color)
                end
            end
        end)
    end
end)

localPlayer:GetPropertyChangedSignal("Team"):Connect(function()
    updateESP()
end)

Players.PlayerAdded:Connect(function()
    task.wait(0.3)
    updateESP()
end)

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= localPlayer then
        p.CharacterAdded:Connect(function()
            task.wait(0.3)
            updateESP()
        end)
    end
end

task.wait(0.3)
updateESP()
