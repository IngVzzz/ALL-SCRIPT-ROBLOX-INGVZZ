-- Cat-GPT | Aimbot + Kamera Survivor | Violence District
-- Saat aimbot ON: kamera perspektif Survivor
-- Saat aimbot OFF: kamera balik ke default Killer

local aimbotEnabled = false
local currentTarget = nil
local maxLockDistance = 35

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local Camera = workspace.CurrentCamera
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- Variabel untuk kamera Survivor
local survivorCamActive = false
local cameraAngleX = 0
local cameraAngleY = 20
local isMousePressed = false
local SURVIVOR_OFFSET = Vector3.new(1.5, 1.5, 4.5)
local HEIGHT_OFFSET = 1.2
local renderStepConnection = nil

-- Fungsi mendapatkan role
local function GetRole()
    if not LocalPlayer.Team then return "Unknown" end
    local name = LocalPlayer.Team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" then return "Survivor" end
    return "Lobby"
end

-- Fungsi mouse lock untuk aimbot
local function lockMouse()
    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    UserInputService.MouseIconEnabled = false
end

local function unlockMouse()
    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    UserInputService.MouseIconEnabled = true
end

-- ========== KAMERA SURVIVOR (Override) ==========
local function enableSurvivorCamera()
    if survivorCamActive then return end
    survivorCamActive = true
    
    -- Reset sudut kamera
    cameraAngleX = 0
    cameraAngleY = 20
    
    -- Ubah pengaturan kamera
    Camera.CameraType = Enum.CameraType.Custom
    Camera.FieldOfView = 75
    LocalPlayer.CameraMode = Enum.CameraMode.Classic
    
    -- Fungsi update kamera setiap frame
    local function updateSurvivorCamera()
        local character = LocalPlayer.Character
        if not character then return end
        
        local head = character:FindFirstChild("Head")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not (head and rootPart) then return end
        
        local targetPosition = head.Position + Vector3.new(0, HEIGHT_OFFSET, 0)
        
        local yawRad = math.rad(cameraAngleX)
        local pitchRad = math.rad(cameraAngleY)
        local rotation = CFrame.new() * CFrame.Angles(0, yawRad, 0) * CFrame.Angles(pitchRad, 0, 0)
        local offsetVector = rotation:VectorToWorldSpace(SURVIVOR_OFFSET)
        local cameraPosition = targetPosition + offsetVector
        local lookAtTarget = targetPosition + Vector3.new(0, -0.5, 0)
        
        Camera.CFrame = CFrame.new(cameraPosition, lookAtTarget)
    end
    
    -- Hentikan render step sebelumnya jika ada
    if renderStepConnection then renderStepConnection:Disconnect() end
    
    renderStepConnection = RunService.RenderStepped:Connect(updateSurvivorCamera)
    
    -- Aktifkan kontrol mouse untuk kamera Survivor
    local mouseInputBegan, mouseInputEnded, mouseInputChanged
    
    mouseInputBegan = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            isMousePressed = true
        end
    end)
    
    mouseInputEnded = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            isMousePressed = false
        end
    end)
    
    mouseInputChanged = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and isMousePressed then
            cameraAngleX = cameraAngleX - input.Delta.X * 0.3
            cameraAngleY = math.clamp(cameraAngleY - input.Delta.Y * 0.3, -30, 60)
        end
    end)
    
    -- Simpan koneksi untuk dimatikan nanti
    renderStepConnection._mouseBegan = mouseInputBegan
    renderStepConnection._mouseEnded = mouseInputEnded
    renderStepConnection._mouseChanged = mouseInputChanged
    
    print("[Cat-GPT] Kamera Survivor AKTIF")
end

local function disableSurvivorCamera()
    if not survivorCamActive then return end
    survivorCamActive = false
    
    -- Matikan render step
    if renderStepConnection then
        if renderStepConnection._mouseBegan then renderStepConnection._mouseBegan:Disconnect() end
        if renderStepConnection._mouseEnded then renderStepConnection._mouseEnded:Disconnect() end
        if renderStepConnection._mouseChanged then renderStepConnection._mouseChanged:Disconnect() end
        renderStepConnection:Disconnect()
        renderStepConnection = nil
    end
    
    -- Kembalikan kamera ke mode default
    Camera.CameraType = Enum.CameraType.Custom
    LocalPlayer.CameraMode = Enum.CameraMode.Classic
    
    -- Reset CFrame kamera ke tampilan default
    task.wait(0.1)
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(character.HumanoidRootPart.Position + Vector3.new(0, 2, 8), character.HumanoidRootPart.Position), 0.5)
    end
    
    print("[Cat-GPT] Kamera Killer DEFAULT AKTIF")
end

-- ========== AIMBOT CORE ==========
local function getClosestTarget()
    local closestTarget = nil
    local shortestDistance = math.huge
    local screenCenter = Camera.ViewportSize / 2
    local playerPosition = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.new(0, 0, 0)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local distanceFromPlayer = (playerPosition - targetPart.Position).Magnitude
                
                if distanceFromPlayer <= maxLockDistance then
                    local screenPoint, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    local distanceOnScreen = (Vector2.new(screenPoint.X, screenPoint.Y) - screenCenter).Magnitude

                    if onScreen and distanceOnScreen < shortestDistance then
                        closestTarget = player
                        shortestDistance = distanceOnScreen
                    end
                end
            end
        end
    end
    return closestTarget
end

local function lockOnTarget()
    if currentTarget and currentTarget.Character then
        local targetPart = currentTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetPart then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, targetPart.Position), 0.9)
        else
            currentTarget = nil
        end
    end
end

-- Handler toggle aimbot + kamera
local function setAimbotState(state)
    aimbotEnabled = state
    
    if aimbotEnabled then
        -- Aimbot ON: kamera Survivor aktif
        lockMouse()
        enableSurvivorCamera()
    else
        -- Aimbot OFF: kamera balik ke default Killer
        unlockMouse()
        disableSurvivorCamera()
        currentTarget = nil
    end
end

-- Loop aimbot
RunService.RenderStepped:Connect(function()
    if aimbotEnabled and GetRole() == "Killer" then
        if not currentTarget then
            currentTarget = getClosestTarget()
        end
        if currentTarget then
            lockOnTarget()
        end
    elseif aimbotEnabled and GetRole() ~= "Killer" then
        setAimbotState(false)
        if button then
            button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            button.BackgroundTransparency = 0.15
            stroke.Color = Color3.fromRGB(255, 100, 100)
        end
    end
end)

-- ========== GUI ==========
local button = nil
local stroke = nil
local ScreenGui = nil

local function updateGUIVisibility()
    if button and ScreenGui then
        if GetRole() == "Killer" then
            ScreenGui.Enabled = true
        else
            ScreenGui.Enabled = false
            if aimbotEnabled then
                setAimbotState(false)
            end
        end
    end
end

local function createGUI()
    if game.CoreGui:FindFirstChild("SimpleAimbot") then
        game.CoreGui.SimpleAimbot:Destroy()
    end

    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SimpleAimbot"
    ScreenGui.Parent = game.CoreGui

    button = Instance.new("ImageButton")
    button.Size = UDim2.new(0, 50, 0, 50)
    button.Position = UDim2.new(1, -210, 1, -420)
    button.AnchorPoint = Vector2.new(1, 1)
    button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    button.BackgroundTransparency = 0.15
    button.Image = "rbxassetid://3926305904"
    button.ImageColor3 = Color3.fromRGB(255, 255, 255)
    button.ImageTransparency = 0.2
    button.Parent = ScreenGui
    button.Draggable = false

    local corner = Instance.new("UICorner", button)
    corner.CornerRadius = UDim.new(1, 0)
    
    stroke = Instance.new("UIStroke", button)
    stroke.Color = Color3.fromRGB(255, 100, 100)
    stroke.Thickness = 2
    stroke.Transparency = 0.5

    local dragging = false
    local dragStart = nil
    local startPos = nil

    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = button.Position
        end
    end)

    button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    button.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            button.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    button.MouseButton1Click:Connect(function()
        if not dragging then
            if GetRole() == "Killer" then
                local newState = not aimbotEnabled
                setAimbotState(newState)
                
                if newState then
                    button.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
                    button.BackgroundTransparency = 0.3
                    stroke.Color = Color3.fromRGB(100, 255, 100)
                else
                    button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                    button.BackgroundTransparency = 0.15
                    stroke.Color = Color3.fromRGB(255, 100, 100)
                end
            else
                button.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                task.wait(0.1)
                button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            end
        end
        dragging = false
    end)
end

-- Inisialisasi
createGUI()
updateGUIVisibility()

LocalPlayer:GetPropertyChangedSignal("Team"):Connect(updateGUIVisibility)

Players.LocalPlayer.CharacterAdded:Connect(function()
    if not aimbotEnabled then
        unlockMouse()
    end
    -- Jika aimbot mati, pastikan kamera default
    if not aimbotEnabled and survivorCamActive then
        disableSurvivorCamera()
    end
end)

print("[Cat-GPT] Script siap. Klik tombol untuk toggle aimbot + kamera Survivor.")
