local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local localPlayer = Players.LocalPlayer

local Config = {
    ESP = {
        Enabled = true,
        Players = {
            ["Killer"] = {Color = Color3.fromRGB(255, 93, 108)},
            ["Survivor"] = {Color = Color3.fromRGB(64, 224, 255)}
        }
    }
}

local activeHighlights = {}

local function GetRole()
    if not localPlayer.Team then return "Unknown" end
    local name = localPlayer.Team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" then return "Survivor" end
    return "Lobby"
end

local function IsESPAllowed()
    local role = GetRole()
    return role == "Killer" or role == "Survivor"
end

local function ShouldShowESP(targetPlayer)
    local localRole = GetRole()
    if localRole == "Unknown" or localRole == "Lobby" then return false end
    if not targetPlayer.Team then return false end
    if targetPlayer == localPlayer then return false end
    
    return true
end

local function GetESPColor(targetPlayer)
    local targetTeam = targetPlayer.Team.Name
    if targetTeam == "Killer" then
        return Config.ESP.Players["Killer"].Color
    else
        return Config.ESP.Players["Survivor"].Color
    end
end

UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.V then
        Config.ESP.Enabled = not Config.ESP.Enabled
        
        for _, highlight in pairs(activeHighlights) do
            if highlight and highlight.Parent then
                highlight.Enabled = Config.ESP.Enabled and IsESPAllowed()
            end
        end
    end
end)

local function ApplyHighlight(obj, color)
    if not obj then return end
    
    local existing = obj:FindFirstChild("RxmmyESP")
    if existing then
        activeHighlights[obj] = nil
        existing:Destroy()
    end
    
    local h = Instance.new("Highlight")
    h.Name = "RxmmyESP"
    h.Adornee = obj
    h.FillColor = color
    h.OutlineColor = color
    h.FillTransparency = 0.8
    h.OutlineTransparency = 0.3
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Enabled = Config.ESP.Enabled and IsESPAllowed()
    h.Parent = obj
    
    activeHighlights[obj] = h
    
    obj.AncestryChanged:Connect(function()
        if not obj.Parent then
            activeHighlights[obj] = nil
        end
    end)
end

local function UpdateAllESP()
    if not Config.ESP.Enabled or not IsESPAllowed() then
        for obj, highlight in pairs(activeHighlights) do
            if highlight then
                pcall(function() highlight:Destroy() end)
            end
        end
        activeHighlights = {}
        return
    end
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Team then
            if ShouldShowESP(p) then
                local color = GetESPColor(p)
                ApplyHighlight(p.Character, color)
            else
                if p.Character then
                    local existing = p.Character:FindFirstChild("RxmmyESP")
                    if existing then
                        activeHighlights[p.Character] = nil
                        existing:Destroy()
                    end
                end
            end
        end
    end
end

local function SetupPlayerESP(p)
    if p == localPlayer then return end
    
    p.CharacterAdded:Connect(function()
        task.wait(0.3)
        UpdateAllESP()
    end)
end

localPlayer:GetPropertyChangedSignal("Team"):Connect(function()
    task.wait(0.2)
    for obj, highlight in pairs(activeHighlights) do
        if highlight then
            pcall(function() highlight:Destroy() end)
        end
    end
    activeHighlights = {}
    UpdateAllESP()
end)

task.spawn(function()
    while true do
        UpdateAllESP()
        task.wait(0.5)
    end
end)

for _, p in ipairs(Players:GetPlayers()) do
    SetupPlayerESP(p)
end

Players.PlayerAdded:Connect(SetupPlayerESP)

task.wait(0.5)
UpdateAllESP()
